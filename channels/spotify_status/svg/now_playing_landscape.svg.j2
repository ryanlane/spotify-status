{% set W = width %}{% set H = height %}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ W }}" height="{{ H }}" viewBox="0 0 {{ W }} {{ H }}" version="1.1">
  <defs>
    <style><![CDATA[
      .bg { fill: {{ '#ffffff' if theme == 'light' else '#111418' }}; }
      .fg { fill: {{ '#111418' if theme == 'light' else '#f5f7fa' }}; font-family: 'Arial','Helvetica',sans-serif; }
      .muted { fill: {{ '#5a636e' if theme == 'light' else '#9aa4af' }}; font-family: 'Arial','Helvetica',sans-serif; }
      .accent { fill: #1db954; }
      .bar-bg { fill: {{ '#e5e7eb' if theme == 'light' else '#1e2530' }}; }
      .bar-fill { fill: {{ '#111418' if theme == 'light' else '#f5f7fa' }}; }
      .small { font-size: 20px; }
      .medium { font-size: 28px; font-weight: 500; }
      .large { font-size: 40px; font-weight: 600; }
      .title { font-size: 44px; font-weight: 600; }
    ]]></style>
  </defs>
  <rect class="bg" x="0" y="0" width="100%" height="100%"/>
  {% if has_track %}
    {% set artSize = (H * 0.9)|int %}
    {% set artX = (H * 0.05)|int %}
    {% set artY = (H * 0.05)|int %}
    <rect x="{{ artX }}" y="{{ artY }}" width="{{ artSize }}" height="{{ artSize }}" rx="12" ry="12" fill="{{ '#eceff3' if theme == 'light' else '#222831' }}"/>
    {% if album_art_url %}
      <image x="{{ artX }}" y="{{ artY }}" width="{{ artSize }}" height="{{ artSize }}" preserveAspectRatio="xMidYMid slice" href="{{ album_art_url }}"/>
    {% endif %}
    {% set textLeft = artX + artSize + 60 %}
    {% set textWidth = W - textLeft - 40 %}
    {% set titleY = artY + 40 %}
    <text x="{{ textLeft }}" y="{{ titleY }}" class="fg title">{{ track_name }}</text>
    <text x="{{ textLeft }}" y="{{ titleY + 60 }}" class="muted medium">{{ artist_name }}</text>
    <text x="{{ textLeft }}" y="{{ titleY + 100 }}" class="muted small">{{ album_name }}</text>
    {% set barY = artY + artSize - 60 %}
    {% set barW = (textWidth)|int %}
    {% set barH = 24 %}
    <rect x="{{ textLeft }}" y="{{ barY }}" width="{{ barW }}" height="{{ barH }}" rx="12" class="bar-bg" />
    <rect x="{{ textLeft }}" y="{{ barY }}" width="{{ (barW * (progress_pct/100))|int }}" height="{{ barH }}" rx="12" class="accent" />
    <text x="{{ textLeft }}" y="{{ barY - 10 }}" class="muted small">{{ (progress_ms // 60000) }}:{{ '%02d' % ((progress_ms // 1000) % 60) }} / {{ (duration_ms // 60000) }}:{{ '%02d' % ((duration_ms // 1000) % 60) }}</text>
    <text x="{{ textLeft }}" y="{{ barY + barH + 40 }}" class="muted small">Device: {{ device }} • {{ 'Playing' if is_playing else 'Paused' }}</text>
  {% else %}
    <text x="50%" y="45%" text-anchor="middle" class="muted large" font-size="72">♪</text>
    <text x="50%" y="60%" text-anchor="middle" class="fg title">No music</text>
    <text x="50%" y="70%" text-anchor="middle" class="muted medium">Start Spotify to see track info</text>
  {% endif %}
</svg>

