{
  "schemaVersion": "2.4",
  "id": "com.spotify.status",
  "name": "Spotify Status Channel",
  "description": "Display currently playing Spotify track album art and metadata",
  "version": "1.0.0",
  "author": "Ryan Lane",
  "settingsType": "advanced",
  "update_schedule": {
    "unit": "minutes",
    "duration": 15,
    "settings_driven": true,
    "settings_key": "slideshow_interval"
  },
  "ui": [
    {
      "element": "x-spotify-status-card",
      "moduleUrl": "/api/channels/com.spotify.status/ui/index.esm.js",
      "styleUrl": "/api/channels/com.spotify.status/ui/styles.css",
      "slots": ["dashboard.gallery", "dashboard.sidebar"],
      "propsSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "user": {"type": "object"},
          "settings": {"type": "object"},
          "stats": {"type": "object"}
        }
      },
      "renderMode": "element",
      "integrity": {
        "module": "sha384-RjLq7ZwdGajSCyb7XwExD8MgFOWAQyOWG5YEJ3rAFaEPdRmUcm0dr3W07go5kiVy",
        "style": "sha384-WDQcixiu+7CxVwxbEb5MdHQjhF7uWwiKCYVLUTgkCwMGmBwThlpklpNsVspPIims"
      }
    },
    {
      "route": "/spotify-status",
      "element": "x-spotify-status-manager",
      "moduleUrl": "/api/channels/com.spotify.status/ui/manage.esm.js",
      "nav": {
        "label": "Spotify Status",
        "icon": "image"
      },
      "renderMode": "element",
      "integrity": {
        "module": "sha384-7JQpQDWv2TXpfW1UfFuAxmAWvb8RRFhmBfBbMzf/MYO2EIvpRQ9AMWHDPmgR6pC4"
      }
    }
  ],
  "settings": {
    "defaults": {
      "client_id": "2de24533eb004c109074237acfd67dce",
      "client_secret": "01f05558cf0c469fafc74a90a585206a", 
      "redirect_uri": "http://127.0.0.1:5000/api/channels/com.spotify.status/callback",
      "update_interval_unit": "minutes",
      "update_interval_value": 30,
      "visual": "Album Art"

    },
    "schema": {
      "type": "object",
      "properties": {
        "client_id": {
          "type": "string",         
          "title": "Spotify API Client ID",
          "description": "Your Spotify API Client ID",
          "default": "2de24533eb004c109074237acfd67dce"
        },
        "client_secret": {
          "type": "string",         
          "title": "Spotify API Client Secret",
          "description": "Your Spotify API Client Secret",
          "default": "01f05558cf0c469fafc74a90a585206a"
        },
        "redirect_uri": {
          "type": "string",         
          "title": "Spotify API Redirect URI",
          "description": "Your Spotify API Redirect URI",
          "default": "http://127.0.0.1:5000/api/channels/com.spotify.status/callback"
        },
        "visual": {
          "type": "string",
          "enum": ["Album Art", "Album, Artist, and Title", "Top Items"],
          "title": "Spotify Visual Option",
          "description": "What do you want to display?"
        },
        "orientation": {
          "type": "string",
          "enum": ["portrait", "landscape"],
          "title": "Display Mode",
          "description": "How to fit images to display"
        },
        "update_interval_unit": {
          "type": "string",
          "enum": ["days", "hours", "minutes", "seconds"],
          "title": "Update Interval Unit",
          "description": "Unit for channel update frequency",
          "default": "minutes"
        },
        "update_interval_value": {
          "type": "integer",
          "minimum": 1,
          "title": "Update Interval Value",
          "description": "Numeric value for channel update frequency",
          "default": 30
        }
      }
    }
  },
  "assets": [
    {
      "name": "logo",
      "url": "/api/channels/com.spotify.status/assets/logo.svg"
    }
  ]
}
